rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Safe isAdmin — uses .get('field', default) so it never throws even if
    // admin/config doesn't exist or is missing the adminUIDs field.
    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/admin/config) &&
        request.auth.uid in
          get(/databases/$(database)/documents/admin/config).data.get('adminUIDs', []);
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Safe isActiveUser — checks the user doc exists before reading accountStatus
    function isActiveUser() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().accountStatus == 'active';
    }

    // ── Admin config ────────────────────────────────────────────────────────────
    match /admin/{doc} {
      allow read: if isAuth();
      allow write: if false; // Only writable via Firebase Console / Cloud Functions
    }

    // ── Users ───────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Users can read their own profile; admins can read any
      allow read: if isOwner(uid) || isAdmin();

      // Profile creation — Google Sign-In (no phoneNumber required).
      allow create: if isOwner(uid) &&
        request.resource.data.keys().hasAll(['name', 'city', 'karmaPoints']) &&
        request.resource.data.karmaPoints == 0;

      // Users can update their own safe fields (name, city, profilePhoto, etc.)
      // but cannot modify karma/trust/status fields (those are server-side only).
      allow update: if isOwner(uid) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['karmaPoints', 'trustLevel', 'totalReports', 'verifiedReports',
                   'flaggedReports', 'accountStatus', 'warningCount', 'bannedAt',
                   'banReason', 'previouslyBanned', 'permanentBan',
                   'createdAt']);

      // Admins can update any user field
      allow update: if isAdmin();

      // Notifications subcollection
      match /notifications/{notifId} {
        allow read: if isOwner(uid);
        allow write: if isAdmin();
        allow update: if isOwner(uid) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      }
    }

    // ── Bhandaras ───────────────────────────────────────────────────────────────
    match /bhandaras/{bhandaraId} {
      // Anyone can read bhandaras (map is public)
      allow read: if true;

      // Only authenticated active users can create bhandaras
      allow create: if isActiveUser() &&
        request.resource.data.reportedBy == request.auth.uid &&
        request.resource.data.photos.size() >= 1 &&
        request.resource.data.title.size() <= 100;

      // Owners can update limited fields; admins can update anything
      allow update: if isAdmin() ||
        (isOwner(resource.data.reportedBy) &&
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['confirmations', 'checkIns', 'flags', 'flagCount',
                    'confirmationCount', 'checkInCount', 'status', 'confidenceScore',
                    'reportedBy']));

      // No client-side deletes
      allow delete: if false;
    }

    // ── Flag tracking ───────────────────────────────────────────────────────────
    match /flagHistory/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false; // Cloud Functions only
    }
  }
}
